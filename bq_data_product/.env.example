# Dataplex Data Product Demo — configuration
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Then authenticate with ADC before running the script:
#
#   gcloud auth application-default login
#   uv run create_data_products.py setup create

# GCP project where the data products will be created.
# The Dataplex and BigQuery APIs must be enabled on this project.
PROJECT_ID=your-gcp-project-id

# Numeric project number for the project above.
# Find it with: gcloud projects describe YOUR_PROJECT_ID --format="value(projectNumber)"
PROJECT_NUMBER=123456789012

# Dataplex location. Must match the BigQuery dataset location (US multi-region → us).
# Common values: us, eu, us-central1, europe-west1
LOCATION=us

# Location for DataScan (data profile) resources.
# DataScans require a regional endpoint — the multi-region "us" is NOT supported.
# A regional scan location (e.g. us-central1) can still scan US multi-region BQ resources.
SCAN_LOCATION=us-central1

# Email address shown as the data product owner in Dataplex Universal Catalog.
OWNER_EMAIL=you@example.com
