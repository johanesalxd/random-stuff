# BigQuery + Dataproc Serverless Spark ETL -- Makefile
#
# Demo quick start:
#   GCP_PROJECT=my-project GCP_REGION=us-central1 make infra-up
#   make seed
#   make deploy
#   make run-demo-pipeline
#   make infra-down
#
# Required env vars (set in shell or sourced from infra/.env):
#   GCS_BUCKET        GCS bucket name (without gs:// prefix)
#   GCP_PROJECT       Google Cloud project ID
#   GCP_REGION        Dataproc/BQ region (e.g. us-central1)
#   BQ_DATASET        BigQuery dataset for the stored procedure (default: pipelines)
#   BQ_CONNECTION     Spark connection ID (short name, not full path)
#
# Optional:
#   RUNTIME_VERSION     Dataproc Serverless runtime (default: 2.3)
#   PIPELINE_VERSION    Wheel version to build/upload (default: 0.1.0)
#   TTL                 Max job lifetime before auto-cancel (default: 1h)
#   SERVICE_ACCOUNT     Dedicated SA for the batch job
#   SUBNET              VPC subnet URI for private networking
#   HISTORY_SERVER      Persistent History Server cluster name

RUNTIME_VERSION  ?= 2.3
PIPELINE_VERSION ?= 0.1.0
WHEEL_FILE        = dist/pipeline-$(PIPELINE_VERSION)-py3-none-any.whl
JDBC_JAR_URL      = https://jdbc.postgresql.org/download/postgresql-42.7.3.jar
JDBC_JAR_LOCAL    = dist/postgresql-42.7.3.jar

.PHONY: help install lint test build upload-gcs submit-batch create-stored-proc \
        deploy clean download-jdbc-jar infra-up infra-down seed run-demo-pipeline demo

# Source infra/.env if it exists (generated by make infra-up)
-include infra/.env
export

help:
	@echo "Demo targets:"
	@echo "  infra-up             Provision all GCP resources (Cloud SQL, GCS, BQ, SA)"
	@echo "  seed                 Load TheLook sample data into Cloud SQL"
	@echo "  run-demo-pipeline    Execute the 2-step demo pipeline via BigQuery SQL"
	@echo "  infra-down           Tear down all GCP resources"
	@echo "  demo                 infra-up + seed + deploy + run-demo-pipeline"
	@echo ""
	@echo "Pipeline targets:"
	@echo "  install              Install dev dependencies via uv"
	@echo "  lint                 Run ruff linter and formatter check"
	@echo "  test                 Run unit tests with pytest"
	@echo "  build                Build the Python wheel"
	@echo "  download-jdbc-jar    Download the PostgreSQL JDBC driver JAR"
	@echo "  upload-gcs           Build + upload wheel, main.py, JDBC JAR to GCS"
	@echo "  submit-batch         Submit a one-off Dataproc Serverless batch job"
	@echo "  create-stored-proc   Create/replace the BQ Spark stored procedure"
	@echo "  deploy               upload-gcs + create-stored-proc"
	@echo "  clean                Remove build artifacts"

# ---------------------------------------------------------------------------
# Development
# ---------------------------------------------------------------------------

install:
	uv sync --all-extras

lint:
	uv run ruff check pipeline/
	uv run ruff format --check pipeline/

test:
	uv run pytest -v

# ---------------------------------------------------------------------------
# Build
# ---------------------------------------------------------------------------

build: clean
	uv build --wheel
	@echo "Built: $(WHEEL_FILE)"

download-jdbc-jar:
	@mkdir -p dist
	@if [ ! -f "$(JDBC_JAR_LOCAL)" ]; then \
		echo "Downloading PostgreSQL JDBC driver..."; \
		curl -fsSL -o $(JDBC_JAR_LOCAL) $(JDBC_JAR_URL); \
		echo "Downloaded: $(JDBC_JAR_LOCAL)"; \
	else \
		echo "JDBC driver already exists: $(JDBC_JAR_LOCAL)"; \
	fi

# ---------------------------------------------------------------------------
# GCS upload
# ---------------------------------------------------------------------------

upload-gcs: build download-jdbc-jar
	@[ -n "$(GCS_BUCKET)" ]  || (echo "ERROR: GCS_BUCKET is not set"  && exit 1)
	@[ -n "$(GCP_PROJECT)" ] || (echo "ERROR: GCP_PROJECT is not set" && exit 1)

	# Upload the pipeline wheel
	gcloud storage cp $(WHEEL_FILE) \
		gs://$(GCS_BUCKET)/wheels/pipeline-$(PIPELINE_VERSION)-py3-none-any.whl

	# Upload the entry point script
	gcloud storage cp pipeline/main.py \
		gs://$(GCS_BUCKET)/pipeline/main.py

	# Upload the JDBC driver JAR
	gcloud storage cp $(JDBC_JAR_LOCAL) \
		gs://$(GCS_BUCKET)/jars/postgresql-42.7.3.jar

	# Upload demo configs (substitute MY_PROJECT placeholder)
	@for YAML in configs/demo/*.yaml; do \
		TABLE=$$(basename $${YAML} .yaml); \
		sed "s|MY_PROJECT|$(GCP_PROJECT)|g" $${YAML} \
		| gcloud storage cp - \
			"gs://$(GCS_BUCKET)/configs/thelook/public/$${TABLE}.yaml"; \
		echo "Uploaded config: $${TABLE}.yaml"; \
	done

	@echo "Uploaded to gs://$(GCS_BUCKET)"

# ---------------------------------------------------------------------------
# Dataproc Serverless: submit a batch job
# ---------------------------------------------------------------------------
# Usage: make submit-batch SOURCE=thelook DB=public TBL=orders RUN_ID=$(uuidgen)

SOURCE          ?= my_source
DB              ?= public
TBL             ?= my_table
RUN_ID          ?= $(shell python3 -c "import uuid; print(uuid.uuid4())")
TTL             ?= 1h
SERVICE_ACCOUNT ?=
SUBNET          ?=
HISTORY_SERVER  ?=

# Build optional flags only when the variable is set
_SA_FLAG     = $(if $(SERVICE_ACCOUNT),--service-account=$(SERVICE_ACCOUNT),)
_SUBNET_FLAG = $(if $(SUBNET),--subnet=$(SUBNET),)
_PHS_FLAG    = $(if $(HISTORY_SERVER),--history-server-cluster=$(HISTORY_SERVER),)

# Packages not in the Dataproc Serverless default Conda env — must be installed at runtime.
# Pinned to match pyproject.toml dependencies.
_PIP_PACKAGES = pydantic==2.13.0,google-cloud-secret-manager==2.16.0,google-cloud-storage==2.10.0,pyyaml==6.0.2

submit-batch:
	@[ -n "$(GCS_BUCKET)" ]    || (echo "ERROR: GCS_BUCKET is not set"    && exit 1)
	@[ -n "$(GCP_PROJECT)" ]   || (echo "ERROR: GCP_PROJECT is not set"   && exit 1)
	@[ -n "$(GCP_REGION)" ]    || (echo "ERROR: GCP_REGION is not set"    && exit 1)

	gcloud dataproc batches submit pyspark \
		gs://$(GCS_BUCKET)/pipeline/main.py \
		--project=$(GCP_PROJECT) \
		--region=$(GCP_REGION) \
		--version=$(RUNTIME_VERSION) \
		--py-files=gs://$(GCS_BUCKET)/wheels/pipeline-$(PIPELINE_VERSION)-py3-none-any.whl \
		--jars=gs://$(GCS_BUCKET)/jars/postgresql-42.7.3.jar \
		--labels=source=$(SOURCE),db=$(DB),tbl=$(TBL) \
		--ttl=$(TTL) \
		$(_SA_FLAG) \
		$(_SUBNET_FLAG) \
		$(_PHS_FLAG) \
		--properties=\
spark.pyspark.python.pip.packages=$(_PIP_PACKAGES),\
spark.dataproc.scaling.version=2 \
		-- \
		--source_name=$(SOURCE) \
		--db_name=$(DB) \
		--tbl_name=$(TBL) \
		--gcs_bucket=$(GCS_BUCKET) \
		--run_id=$(RUN_ID)

# ---------------------------------------------------------------------------
# BigQuery Spark Stored Procedure
# ---------------------------------------------------------------------------

create-stored-proc:
	@[ -n "$(GCS_BUCKET)" ]    || (echo "ERROR: GCS_BUCKET is not set"    && exit 1)
	@[ -n "$(GCP_PROJECT)" ]   || (echo "ERROR: GCP_PROJECT is not set"   && exit 1)
	@[ -n "$(GCP_REGION)" ]    || (echo "ERROR: GCP_REGION is not set"    && exit 1)
	@[ -n "$(BQ_DATASET)" ]    || (echo "ERROR: BQ_DATASET is not set"    && exit 1)
	@[ -n "$(BQ_CONNECTION)" ] || (echo "ERROR: BQ_CONNECTION is not set" && exit 1)

	# Substitute placeholders and execute
	sed \
		-e "s|<MY_PROJECT>|$(GCP_PROJECT)|g" \
		-e "s|<MY_REGION>|$(GCP_REGION)|g" \
		-e "s|<MY_DATASET>|$(BQ_DATASET)|g" \
		-e "s|<MY_CONNECTION_NAME>|$(BQ_CONNECTION)|g" \
		-e "s|<MY_GCS_BUCKET>|$(GCS_BUCKET)|g" \
		sql/create_stored_procedures.sql \
	| bq query \
		--project_id=$(GCP_PROJECT) \
		--location=$(GCP_REGION) \
		--nouse_legacy_sql

	@echo "Stored procedure created: $(GCP_PROJECT).$(BQ_DATASET).run_pipeline"

# ---------------------------------------------------------------------------
# Composite targets
# ---------------------------------------------------------------------------

deploy: upload-gcs create-stored-proc
	@echo "Deploy complete. Pipeline is ready."
	@echo "Call via SQL: CALL \`$(GCP_PROJECT).$(BQ_DATASET).run_pipeline\`(...)"

clean:
	rm -rf dist/ build/ *.egg-info

# ---------------------------------------------------------------------------
# Demo infrastructure
# ---------------------------------------------------------------------------

infra-up:
	@[ -n "$(GCP_PROJECT)" ] || (echo "ERROR: GCP_PROJECT is not set" && exit 1)
	@[ -n "$(GCP_REGION)" ]  || (echo "ERROR: GCP_REGION is not set"  && exit 1)
	GCP_PROJECT=$(GCP_PROJECT) GCP_REGION=$(GCP_REGION) \
	GCS_BUCKET=$(GCS_BUCKET) BQ_DATASET=$(BQ_DATASET) BQ_CONNECTION=$(BQ_CONNECTION) \
	bash infra/setup.sh

infra-down:
	@[ -f infra/.env ] || (echo "ERROR: infra/.env not found. Run make infra-up first." && exit 1)
	bash infra/teardown.sh

# ---------------------------------------------------------------------------
# Seed Cloud SQL with TheLook sample data
# ---------------------------------------------------------------------------

seed:
	@[ -f infra/.env ] || (echo "ERROR: infra/.env not found. Run make infra-up first." && exit 1)
	uv run python scripts/seed_data.py

# ---------------------------------------------------------------------------
# Run the 2-step demo pipeline via BigQuery SQL
# ---------------------------------------------------------------------------

run-demo-pipeline:
	@[ -n "$(GCP_PROJECT)" ]   || (echo "ERROR: GCP_PROJECT is not set"   && exit 1)
	@[ -n "$(GCP_REGION)" ]    || (echo "ERROR: GCP_REGION is not set"    && exit 1)
	@[ -n "$(GCS_BUCKET)" ]    || (echo "ERROR: GCS_BUCKET is not set"    && exit 1)
	@[ -n "$(BQ_DATASET)" ]    || (echo "ERROR: BQ_DATASET is not set"    && exit 1)
	sed \
		-e "s|MY_PROJECT|$(GCP_PROJECT)|g" \
		-e "s|MY_DATASET|$(BQ_DATASET)|g" \
		-e "s|MY_GCS_BUCKET|$(GCS_BUCKET)|g" \
		sql/demo_pipeline.sql \
	| bq query \
		--project_id=$(GCP_PROJECT) \
		--location=$(GCP_REGION) \
		--nouse_legacy_sql
	@echo ""
	@echo "Pipeline complete. Check BigQuery:"
	@echo "  raw_thelook.orders       -- ingested from Cloud SQL (full load)"
	@echo "  raw_thelook.users        -- ingested from Cloud SQL (merge/upsert)"
	@echo "  raw_thelook.order_items  -- ingested from Cloud SQL (incremental)"
	@echo "  analytics.daily_revenue  -- downstream aggregate (pure SQL)"

# ---------------------------------------------------------------------------
# All-in-one demo
# ---------------------------------------------------------------------------

demo: infra-up seed deploy run-demo-pipeline
	@echo ""
	@echo "=== Demo complete ==="
	@echo "To clean up: make infra-down"
