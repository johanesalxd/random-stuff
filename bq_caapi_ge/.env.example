GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_PROJECT_NUMBER=your-project-number
GOOGLE_CLOUD_LOCATION=global
BIGQUERY_DATASET_ID=thelook_ecommerce
AGENT_ORDERS_ID=order_user_agent
AGENT_INVENTORY_ID=inventory_product_agent
GEMINI_APP_ID=your-gemini-app-id

# Session state keys where Gemini Enterprise deposits each user's OAuth token.
# Must match the authorizationId values used when running scripts/setup_auth.py.
# The deployed agents read these keys directly via external_access_token_key --
# no client credentials required on the agent side.
AUTH_RESOURCE_ORDERS=bq-caapi-oauth
AUTH_RESOURCE_INVENTORY=bq-caapi-oauth-inventory

# OAuth client credentials -- only needed by scripts/setup_auth.py to create
# the Gemini Enterprise authorization resources. Not used by the deployed agents.
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret

GOOGLE_GENAI_USE_VERTEXAI=TRUE
