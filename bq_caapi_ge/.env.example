# --- Shared (both default and advanced paths) ---
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
BIGQUERY_DATASET_ID=thelook_ecommerce
AGENT_ORDERS_ID=order_user_agent
AGENT_INVENTORY_ID=inventory_product_agent

# Gemini Enterprise app ID. Used by scripts/register_ge_agents.py to register
# CA API data agents as A2A agents in GE via the Discovery Engine API.
# Find this in the GE console URL or by listing engines via the Discovery Engine API.
GEMINI_APP_ID=your-gemini-app-id

# OAuth client credentials -- required to create authorization resources in GE.
# Download the OAuth client JSON from GCP Console > APIs & Services > Credentials,
# then copy client_id and client_secret here.
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Authorization Resource IDs
# Note: Gemini Enterprise requires a 1:1 mapping between agents and auth resources.
# Session state keys where Gemini Enterprise deposits each user's OAuth token.
# Must match the authorizationId values used when running scripts/setup_auth.py.
# The deployed agents read these keys directly via external_access_token_key --
# no client credentials required on the agent side.
AUTH_RESOURCE_ORDERS=bq-caapi-oauth-orders
AUTH_RESOURCE_INVENTORY=bq-caapi-oauth-inventory

# --- Advanced path only (ADK runtime + Agent Engine deployment) ---
# See advanced/README.md for details.
GOOGLE_CLOUD_PROJECT_NUMBER=your-project-number
GOOGLE_GENAI_USE_VERTEXAI=TRUE
# Set after running: bash advanced/scripts/deploy_agents.sh
# ORDERS_REASONING_ENGINE_ID=your-orders-reasoning-engine-id
# INVENTORY_REASONING_ENGINE_ID=your-inventory-reasoning-engine-id
