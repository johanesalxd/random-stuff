# Cross-Cloud Lakehouse demo — configuration TEMPLATE (safe to commit).
#
# Copy this to `config.local.env` and fill in real values. `config.local.env`
# is git-ignored so your account ID / bucket names never reach this public repo.
#
#     cp config.example.env config.local.env
#
# AWS credentials themselves are NOT stored here — they live in ~/.aws/
# (created via `aws configure`). This file only holds non-secret identifiers.
#
# This repo is the self-contained, AWS-extended version of the Next '26 keynote
# demo "Raw data to forecasting in seconds with AI agents". The Froyo storyline
# (Midnight Swirl) runs end-to-end from BigQuery: allergen knowledge in native
# BQ is joined with customer-loyalty + sales data that physically lives in AWS
# S3/Glue (Apache Iceberg), federated into BigQuery via cross-cloud Lakehouse.

# ---- AWS ----
export AWS_ACCOUNT_ID="123456789012"        # your 12-digit AWS account ID
export AWS_REGION="us-east-1"                # AWS region for S3 + Glue
export AWS_IAM_USER="lakehouse-demo-cli"     # IAM user used for the demo (deleted at teardown)
export AWS_ROLE_NAME="biglake_glue_federation_role"
export AWS_POLICY_NAME="biglake_glue_permissions"
export S3_BUCKET="CHANGE-ME-unique-lakehouse-demo"   # globally-unique bucket name

# Glue database (Iceberg namespace) + the two Froyo Iceberg tables that live in AWS.
export GLUE_DATABASE="froyo_lakehouse"
export FROYO_LOYALTY_TABLE="global_loyalty"  # customer loyalty (joined with allergens)
export FROYO_SALES_TABLE="sales_history"     # historical sales (BQML ARIMA_PLUS forecast)

# ---- GCP ----
export GCP_PROJECT="my-gcp-project"
export GCP_REGION="us-east4"                 # Lakehouse/BigQuery region (pairs with AWS us-east-1)
export FEDERATED_CATALOG="demo_glue_cat"

# Native BigQuery dataset (must be co-located in GCP_REGION so it can JOIN the
# federated AWS tables in a single query). Holds the Knowledge-Catalog-extracted
# allergen/recipe/product knowledge (seeded deterministically; optionally the
# real Dataplex extraction publishes here too).
export FROYO_NATIVE_DATASET="froyo_demo_ue4"

# ---- Knowledge Catalog (Dataplex) real-extraction path (optional) ----
export GCS_PDF_BUCKET="CHANGE-ME-unique-froyo-pdfs"  # GCS bucket for recipe/supplier PDFs (in GCP_REGION)
export BQ_CONNECTION_ID="froyo_pdf_connection"       # BQ Cloud Resource connection for the DataScan
export DATASCAN_ID="froyo-profile-stg1"              # Dataplex DataScan id
