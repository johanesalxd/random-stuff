# Cross-Cloud Lakehouse demo — configuration TEMPLATE (safe to commit).
#
# Copy this to `config.local.env` and fill in real values. `config.local.env`
# is git-ignored so your account ID / bucket names never reach this public repo.
#
#     cp config.example.env config.local.env
#
# AWS credentials themselves are NOT stored here — they live in ~/.aws/
# (created via `aws configure`). This file only holds non-secret identifiers.

# ---- AWS ----
export AWS_ACCOUNT_ID="123456789012"        # your 12-digit AWS account ID
export AWS_REGION="us-east-1"                # AWS region for S3 + Glue
export AWS_IAM_USER="lakehouse-demo-cli"     # IAM user used for the demo (deleted at teardown)
export AWS_ROLE_NAME="biglake_glue_federation_role"
export AWS_POLICY_NAME="biglake_glue_permissions"
export S3_BUCKET="CHANGE-ME-unique-lakehouse-demo"   # globally-unique bucket name
export GLUE_DATABASE="demo_db"
export ICEBERG_TABLE="events"

# ---- GCP ----
export GCP_PROJECT="my-gcp-project"
export GCP_REGION="us-east4"                 # Lakehouse/BigQuery region (pairs with AWS us-east-1)
export FEDERATED_CATALOG="demo_glue_cat"
